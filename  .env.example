# Django Settings
DJANGO_SECRET_KEY=your-production-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.balirent.com,localhost
DJANGO_LOG_LEVEL=INFO

# Database
DATABASE_URL=postgres://user:password@localhost:5432/bali_rent

# Redis / Celery
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# JWT
JWT_ACCESS_LIFETIME_MINS=60
JWT_REFRESH_LIFETIME_DAYS=7

# Throttling
THROTTLE_ANON=100/day
THROTTLE_USER=1000/day

# Payments
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYMENT_SUCCESS_URL=https://balirent.com/payment/success
PAYMENT_CANCEL_URL=https://balirent.com/payment/cancel
CRYPTO_PAYMENT_API_KEY=your-crypto-api-key
CRYPTO_PAYMENT_WEBHOOK_SECRET=your-crypto-webhook-secret

# Security
SECURE_SSL_REDIRECT=True
