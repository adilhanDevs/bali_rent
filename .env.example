# Copy this file to .env and fill in your values

# REQUIRED: generate a new secret key for production
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hosts
# Example: yourusername.pythonanywhere.com
ALLOWED_HOSTS=yourusername.pythonanywhere.com

# Comma-separated list of allowed CORS origins (your frontend URL)
# Example: https://yourfrontend.com,https://www.yourfrontend.com
CORS_ALLOWED_ORIGINS=https://yourusername.pythonanywhere.com
