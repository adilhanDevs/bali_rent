# Copy this file to .env and fill in your values

# REQUIRED: generate a new secret key for production
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=bali21.pythonanywhere.com

# Allow ALL origins (любые домены могут обращаться к API)
# Используй True для открытого API; False — только список ниже
CORS_ALLOW_ALL_ORIGINS=True

# Используется только если CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://bali21.pythonanywhere.com,http://localhost:5173,http://localhost:8081
